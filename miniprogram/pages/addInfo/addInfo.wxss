.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #f5f5f5;
}

.search-input {
  flex: 1;
  margin-right: 20rpx;
  padding: 10rpx;
  background-color: #fff;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.menu-icon {
  width: 50rpx;
  height: 50rpx;
}

.content {
  flex: 1;
  display: flex;
}

.step-indicator-column {
  width: 200rpx;
  background-color: #f5f5f5;
  padding: 20rpx 0;
}

.step-indicator {
  padding: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.step-indicator.active {
  color: #333;
  font-weight: bold;
}

.selector-column {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}
.container {
  display: flex;
}

.van-sidebar {
  flex: 0 0 200rpx; /* 侧边导航宽度 */
}

.content {
  flex: 1;
  padding: 30rpx;
}

.table-header-container {
  position: absolute;
  top: 20px;  /* 从顶部向下移动 10px */
  left: 50px;  /* 从左侧向右移动 20px */
}

.table-header {
  display: flex;
  flex-direction: row;
  background-color: #0dd1d8;  /* 设置表头的背景颜色 */
}

.table-cell {
  padding: 10px;
}
.my-button {
  width: 50px;
  height: 100px;
  font-size: 10px;
  border: 1px solid black;
}
.my1-button {
  width: 50px;
  height: 100px;
  font-size: 15px;
}

tr {
  display: flex;
  height: 30px;
}

#my-view {
  position: absolute;
  top: 240px;
  left: 120px;
  margin: 20px 50px 0 0;
  width: 200px;
  height: 100px;
  max-width: 200px;
  max-height: 100px;
}
